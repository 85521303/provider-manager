{
  "name": "codex-provider-manager",
  "version": "0.1.0",
  "private": true,
  "description": "Local web tool for moving, deleting, and syncing Codex conversations across model providers.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "desktop": "powershell -ExecutionPolicy Bypass -File ./start-desktop.ps1",
    "build:exe": "node build-exe.js",
    "check": "node --check server.js && node --check public/app.js"
  },
  "engines": {
    "node": ">=18"
  }
}
