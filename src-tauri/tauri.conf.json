{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProviderManager",
  "version": "0.1.0",
  "identifier": "com.zang.providermanager",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ProviderManager",
        "width": 1280,
        "height": 860,
        "minWidth": 1052,
        "minHeight": 700,
        "resizable": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "../dist/sidecar/provider-manager"
    ]
  }
}
